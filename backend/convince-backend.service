[Unit]
Description=Convince AI Backend
After=network.target

[Service]
Type=exec
User=aloo
Group=aloo
WorkingDirectory=/data/home/convince-ai/backend
Environment=PATH=/data/home/convince-ai/venv/bin
Environment=PYTHONPATH=/data/home/convince-ai/backend
ExecStart=/data/home/convince-ai/venv/bin/gunicorn -c gunicorn.conf.py app:app
ExecReload=/bin/kill -s HUP $MAINPID
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=convince-backend

# Security settings
NoNewPrivileges=true
DynamicUser=false
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=/data/home/convince-ai/backend
PrivateTmp=true

[Install]
WantedBy=multi-user.target
